graph TB
    %% ── External Data Sources ──
    subgraph Sources["🔗 Source Platforms (External)"]
        BS["BusSeat.lk"]
        BL["Bus.LK"]
        MG["Magiya.lk"]
        SE["SLTB eSeat"]
        BT["BusTicket.gov.lk"]
        RN["Rathna Travels"]
        G12["12Go Asia"]
    end

    %% ── GitHub Actions ──
    subgraph GHA["⏱️ GitHub Actions (Scheduler)"]
        WF["nightly-scrape.yml<br/>Cron: 2:00 AM IST"]
        TRIG["workflow_dispatch<br/>(Manual Trigger)"]
    end

    %% ── Scrapers ──
    subgraph Scrapers["🐍 Python Scrapers"]
        BASE["BaseScraper<br/>(httpx + BS4 + retries)"]
        S1["busseat.py"]
        S2["bus_lk.py"]
        S3["magiya.py"]
        S4["sltb_eseat.py"]
        S5["busticket_gov.py"]
        S6["rathna.py"]
        S7["go12.py"]
        ORCH["run_all.py<br/>(Orchestrator)"]
    end

    %% ── Data Layer ──
    subgraph Data["💾 Data Layer"]
        JSON["data/output/*.json<br/>(Scraped JSON Files)"]
        IMPORT["import_to_db.py<br/>(Normalize + Upsert)"]
        SQLITE[("data/buses.db<br/>SQLite (WAL Mode)")]
        CFG["config/<br/>station_mappings.json<br/>operator_mappings.json<br/>platforms.json"]
    end

    %% ── Backend ──
    subgraph API["🚀 FastAPI Backend"]
        MAIN["main.py<br/>(Uvicorn + Gunicorn)"]
        SEARCH["/api/search"]
        ROUTES["/api/routes"]
        STATIONS["/api/stations<br/>(Autocomplete)"]
        PLATFORMS["/api/platforms"]
        HEALTH["/api/health"]
    end

    %% ── Frontend ──
    subgraph Web["🖥️ Next.js Frontend"]
        HOME["/ (Home)<br/>Search Form"]
        RESULTS["/search<br/>Results Comparison"]
        DETAIL["/route/[id]<br/>Route Detail"]
        COMPS["Components<br/>SearchForm | RouteCard<br/>StationAutocomplete<br/>PlatformBadge"]
    end

    %% ── Deployment ──
    subgraph Infra["☁️ VPS Infrastructure"]
        NGINX["Nginx<br/>(Reverse Proxy)"]
        PM2["PM2<br/>(Process Manager)"]
        SYSTEMD["systemd<br/>(FastAPI Service)"]
    end

    %% ── Users ──
    USER["👤 Passenger<br/>(Mobile/Desktop)"]

    %% ── Edges: Source → Scrapers ──
    BS -->|"HTTP GET/POST"| S1
    BL -->|"HTTP GET/POST"| S2
    MG -->|"HTTP GET/POST"| S3
    SE -->|"HTTP GET/POST"| S4
    BT -->|"HTTP GET/POST"| S5
    RN -->|"HTTP GET/POST"| S6
    G12 -->|"HTTP GET/POST"| S7

    %% ── Edges: GHA → Scrapers ──
    WF -->|"Triggers"| ORCH
    TRIG -->|"Manual Run"| ORCH
    ORCH --> S1
    ORCH --> S2
    ORCH --> S3
    ORCH --> S4
    ORCH --> S5
    ORCH --> S6
    ORCH --> S7
    BASE -.->|"Inherits"| S1
    BASE -.->|"Inherits"| S2
    BASE -.->|"Inherits"| S3
    BASE -.->|"Inherits"| S4
    BASE -.->|"Inherits"| S5
    BASE -.->|"Inherits"| S6
    BASE -.->|"Inherits"| S7

    %% ── Edges: Scrapers → Data ──
    S1 -->|"Writes"| JSON
    S2 -->|"Writes"| JSON
    S3 -->|"Writes"| JSON
    S4 -->|"Writes"| JSON
    S5 -->|"Writes"| JSON
    S6 -->|"Writes"| JSON
    S7 -->|"Writes"| JSON
    JSON -->|"Reads"| IMPORT
    CFG -->|"Normalization Rules"| IMPORT
    IMPORT -->|"Upserts"| SQLITE

    %% ── Edges: Data → API ──
    SQLITE -->|"aiosqlite (Reads)"| API
    CFG -->|"Reads at Startup"| API
    SEARCH --> MAIN
    ROUTES --> MAIN
    STATIONS --> MAIN
    PLATFORMS --> MAIN
    HEALTH --> MAIN

    %% ── Edges: API → Frontend ──
    MAIN -->|"JSON Response"| Web
    HOME -->|"SSR Fetch"| SEARCH
    HOME -->|"Autocomplete"| STATIONS
    RESULTS -->|"Fetch Results"| SEARCH
    DETAIL -->|"Fetch Detail"| ROUTES
    COMPS -.->|"Used by"| HOME
    COMPS -.->|"Used by"| RESULTS
    COMPS -.->|"Used by"| DETAIL

    %% ── Edges: Frontend → User ──
    USER -->|"Visits"| NGINX
    NGINX -->|"Proxies /"| Web
    NGINX -->|"Proxies /api/*"| MAIN

    %% ── Edges: VPS Management ──
    SYSTEMD -->|"Manages"| MAIN
    PM2 -->|"Manages"| Web

    %% ── Styling ──
    classDef source fill:#fca5a5,stroke:#dc2626,color:#000
    classDef gha fill:#fcd34d,stroke:#d97706,color:#000
    classDef scraper fill:#93c5fd,stroke:#2563eb,color:#000
    classDef data fill:#a7f3d0,stroke:#059669,color:#000
    classDef api fill:#c4b5fd,stroke:#7c3aed,color:#000
    classDef web fill:#f9a8d4,stroke:#db2777,color:#000
    classDef infra fill:#e5e7eb,stroke:#6b7280,color:#000

    class BS,BL,MG,SE,BT,RN,G12 source
    class WF,TRIG gha
    class BASE,S1,S2,S3,S4,S5,S6,S7,ORCH scraper
    class JSON,IMPORT,SQLITE,CFG data
    class MAIN,SEARCH,ROUTES,STATIONS,PLATFORMS,HEALTH api
    class HOME,RESULTS,DETAIL,COMPS web
    class NGINX,PM2,SYSTEMD infra
